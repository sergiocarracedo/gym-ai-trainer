# Discord Bot Configuration
# Get these from https://discord.com/developers/applications

# Discord bot token (required)
DISCORD_TOKEN=your-bot-token-here

# Discord application client ID (required)
DISCORD_CLIENT_ID=your-client-id-here

# Discord server/guild ID (required)
# Enable Developer Mode in Discord, right-click your server → Copy Server ID
DISCORD_GUILD_ID=your-guild-id-here

# Discord channel ID to auto-bind to gym-ai-trainer project (optional)
# Enable Developer Mode, right-click the channel → Copy Channel ID
# If not set, you'll need to run /use gym-ai-trainer in your Discord channel
DISCORD_CHANNEL_ID=your-channel-id-here

# Discord user IDs allowed to use the bot (optional, comma-separated)
# Leave empty to allow all users in the server
DISCORD_ALLOWED_USER_IDS=123456789012345678,987654321098765432

# OpenAI API key for voice transcription (optional)
# Required if you want to use voice messages in Discord
OPENAI_API_KEY=sk-your-openai-api-key-here
