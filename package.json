{
  "name": "gym-ai-trainer",
  "version": "1.0.0",
  "description": "AI-powered personal gym trainer using Hevy workout data",
  "type": "module",
  "scripts": {
    "start": "cd agent && ./start.sh",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint agent/.opencode/skills/**/*.ts",
    "lint:fix": "oxlint --fix agent/.opencode/skills/**/*.ts",
    "format": "oxfmt --write agent/.opencode/skills/**/*.ts",
    "format:check": "oxfmt --check agent/.opencode/skills/**/*.ts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "lefthook": "^2.1.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "dotenv": "^16.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
